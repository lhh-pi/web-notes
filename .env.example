# Web Notes — Environment Configuration
# ======================================
# Copy to .env and customize if needed.
#
# Server host/port are configured in config.json (shared between Python and
# the Chrome extension). Edit config.json to change them.
#
# NOTE_STORAGE_PATH: relative to the project root (note/).
#   The default ../../../../notes means:
#   note/ → private_projects/ → 1_codes/ → OneDrive/ → notes/

NOTE_STORAGE_PATH=../../3_datas/web_notes
