{
  "manifest_version": 3,
  "name": "Web Notes",
  "version": "0.1.0",
  "description": "Highlight and annotate any web page. Notes sync across devices via cloud storage.",
  "permissions": [
    "contextMenus",
    "storage",
    "sidePanel",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:2463/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "css": ["src/styles/highlight.css"],
      "run_at": "document_end"
    }
  ],
  "side_panel": {
    "default_path": "src/sidebar/index.html"
  },
  "action": {
    "default_title": "Web Notes",
    "default_icon": {
      "16": "src/assets/icons/icon16.png",
      "48": "src/assets/icons/icon48.png",
      "128": "src/assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "src/assets/icons/icon16.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/assets/icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
